{
  "name": "@reelgen/renderer",
  "version": "0.10.5",
  "description": "A headless renderer for revideo",
  "main": "lib/server/index.js",
  "author": "endersmoon",
  "homepage": "https://github.com/endersmoon/reelgen",
  "bugs": "https://github.com/endersmoon/reelgen/issues",
  "license": "MIT",
  "scripts": {
    "build": "npm run client:build && npm run server:build",
    "postbuild": "ncp renderer.html lib/renderer.html",
    "client:build": "tsc --project client/tsconfig.json",
    "client:dev": "tsc -w --project client/tsconfig.json",
    "server:build": "tsc --project server/tsconfig.json",
    "server:dev": "tsc -w --project server/tsconfig.json"
  },
  "files": [
    "lib",
    "types"
  ],
  "dependencies": {
    "@reelgen/ffmpeg": "^0.10.5",
    "@reelgen/vite-plugin": "^0.10.5",
    "puppeteer": "^24.0.0",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@reelgen/core": "^0.10.5",
    "ncp": "^2.0.0"
  },
  "gitHead": "55f8702fec1c96ba43c5ea2eb266216f6d5db9c6"
}
